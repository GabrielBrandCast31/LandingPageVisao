# ============================================================
# Visão API — Environment configuration
# ============================================================

# Application
APP_NAME=Visão API
ENVIRONMENT=development

# ---- DATABASE ----
# LOCAL (SQLite) — default, sem configuração extra
DATABASE_URL=sqlite+aiosqlite:///./visao.db

# PRODUÇÃO (Supabase / PostgreSQL)
# Trocar prefixo "postgresql://" por "postgresql+asyncpg://"
# DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# CORS — domínios autorizados (separados por vírgula)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---- E-MAIL TRANSACIONAL ----
# Local: vazio → grava .eml em backend/outbox/
# Produção: setar RESEND_API_KEY para enviar de verdade
RESEND_API_KEY=
EMAIL_FROM=Visão <contato@visaobr.com.br>
EMAIL_REPLY_TO=contato.visaobr@gmail.com

# ---- INTEGRAÇÕES ----
# Link público de agendamento Google Calendar (Felipe)
CALENDAR_BOOKING_URL=https://calendar.app.google/PLACEHOLDER

# WhatsApp comercial (formato internacional, sem +)
WHATSAPP_NUMBER=5521997079059

# URL pública da landing (usado nos e-mails)
PUBLIC_SITE_URL=http://localhost:3000

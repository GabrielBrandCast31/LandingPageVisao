# URL pública do site (usada em metadata/OG e logs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Webhook do Google Apps Script publicado a partir da planilha de controle.
# Vazio = envio desativado (lead é exibido localmente mas não persistido).
# Como gerar: ver docs/apps-script.gs e publicar como "Implementar > Web App > Acesso: qualquer pessoa"
NEXT_PUBLIC_LEAD_WEBHOOK_URL=

# Link de agendamento Google Calendar (Felipe).
NEXT_PUBLIC_BOOKING_URL=https://calendar.app.google/PLACEHOLDER

# WhatsApp comercial (formato internacional, sem +).
NEXT_PUBLIC_WHATSAPP_NUMBER=5521997079059

# Analytics (deixe em branco para desabilitar).
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GTM_ID=
